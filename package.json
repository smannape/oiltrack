{
  "name": "crude-radar",
  "version": "5.3.11",
  "description": "Live Oil Market Intelligence — Netlify Pro",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "refresh": "curl -X POST https://YOUR-SITE.netlify.app/api/oil-refresh",
    "status": "curl https://YOUR-SITE.netlify.app/api/oil-meta",
    "telegram-register": "curl -X POST $npm_config_url/api/telegram-register",
    "webhook-info": "curl \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/getWebhookInfo\""
  },
  "dependencies": {
    "@netlify/blobs": "^7.3.0",
    "@netlify/functions": "^2.8.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "netlify-cli": "^17.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
